# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Fireworks (prompt enhancement)
FIREWORKS_API_KEY=fw_...

# Environment
ENVIRONMENT=development

# Paths (relative to backend-ts/)
REMOTION_PROJECT_PATH=./remotion_project
REMOTION_JOBS_PATH=./remotion_jobs
UPLOAD_DIR=./uploads
OUTPUT_DIR=./final_vids

# Claude Code executable (path to `claude` CLI binary)
CLAUDE_CODE_PATH=/Users/you/.local/bin/claude

# Rendering
MAX_RENDER_TIMEOUT=600
CLAUDE_MODEL=claude-sonnet-4-5-20250929
DEFAULT_FPS=30
DEFAULT_WIDTH=1920
DEFAULT_HEIGHT=1080
